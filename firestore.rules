rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own data
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Subscriptions — read only for authenticated users
    match /subscriptions/{email} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Push subscriptions — own only
    match /push_subscriptions/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Social feed posts
    match /posts/{postId} {
      // Anyone logged in can read all posts
      allow read: if request.auth != null;
      // Create: only own posts
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      // Update: only to change likes array
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']);
      // Delete: only own posts
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }
  }
}
